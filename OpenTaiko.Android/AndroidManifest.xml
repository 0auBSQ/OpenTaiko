<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
	<!-- OpenTaiko online features (room codes / P2P) -->
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<!-- The renderer needs GLES 3.0 (glBlitFramebuffer + the engine's ES3 paths) -->
	<uses-feature android:glEsVersion="0x00030000" android:required="true" />
	<uses-feature android:name="android.hardware.touchscreen" android:required="true" />
	<application
		android:label="OpenTaiko"
		android:icon="@mipmap/ic_launcher"
		android:hardwareAccelerated="true"
		android:largeHeap="true"
		android:allowBackup="true">
		<!-- android:name/theme/activity are declared by the [Activity] attribute in MainActivity.cs -->
	</application>
</manifest>